rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funciones de ayuda
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Usamos el token personalizado o el campo en Firestore si ya lo activaste
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }
    
    // Reglas para la colección de usuarios
    match /users/{userId} {
      // Admin puede leer todos los perfiles de usuario
      allow read: if isAdmin();
      // Un usuario solo puede leer y modificar su propio documento
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() && request.auth.uid == userId 
                      && !request.resource.data.keys().contains('isAdmin');
      
      allow update: if (isAdmin()) || 
                      (isSignedIn() && request.auth.uid == userId 
                      && (request.resource.data.isAdmin == resource.data.isAdmin || !request.resource.data.keys().contains('isAdmin')));
    }

    // Reglas para la colección de slots / agenda
    match /slots/{slotId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isAdmin() || request.auth.uid == request.resource.data.teacherId);
      allow update, delete: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.teacherId);
    }
    
    // Por seguridad, bloqueamos cualquier otra colección no definida
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}

